# Server
PORT=4000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=event_booking

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# How many booking jobs a single worker processes concurrently.
# Correctness does NOT depend on this being 1 — see README (row-level locking).
BOOKING_WORKER_CONCURRENCY=5

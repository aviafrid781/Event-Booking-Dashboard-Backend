# Server
PORT=4000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Static bearer token required by the frontend and backend for API requests.
API_TOKEN=super-secret-token

# How many booking jobs a single worker processes concurrently.
# Correctness does NOT depend on this being 1 — see README (row-level locking).
BOOKING_WORKER_CONCURRENCY=5
